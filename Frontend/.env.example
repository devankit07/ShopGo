# ShopGo Frontend uses Vite — not Next.js. Only names starting with VITE_ are bundled into the client.
# Optional: same public key_id as RAZORPAY_KEY_ID in Backend/.env. If omitted, the app fetches /api/payment/config.
# VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
#
# Never put RAZORPAY_KEY_SECRET here — it belongs only in Backend/.env.
